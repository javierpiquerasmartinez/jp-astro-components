---
import type { NavbarProps } from './Navbar.types';

type Props = NavbarProps;

const { links, logo, logoHref = '/', sticky = true } = Astro.props;
---

<header class:list={['jp-navbar', { 'jp-navbar--sticky': sticky }]} id="jp-navbar">
  <nav class="jp-navbar__inner" aria-label="Main navigation">
    <a href={logoHref} class="jp-navbar__logo">
      {logo ?? 'jp'}
    </a>

    <ul class="jp-navbar__links" id="jp-navbar-links" role="list">
      {
        links.map((link) => (
          <li>
            <a href={link.href} class="jp-navbar__link">
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <button
      class="jp-navbar__hamburger"
      id="jp-navbar-toggle"
      aria-expanded="false"
      aria-controls="jp-navbar-links"
      aria-label="Toggle navigation menu"
    >
      <span class="jp-navbar__bar"></span>
      <span class="jp-navbar__bar"></span>
      <span class="jp-navbar__bar"></span>
    </button>
  </nav>
</header>

<style>
  .jp-navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    transition:
      background-color 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      backdrop-filter 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      border-bottom-color 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    border-bottom: 1px solid transparent;
  }

  .jp-navbar--scrolled {
    background-color: rgba(10, 10, 10, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom-color: rgba(232, 255, 71, 0.15);
  }

  .jp-navbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
  }

  .jp-navbar__logo {
    font-size: 1.1rem;
    font-weight: 700;
    color: #e8ff47;
    text-decoration: none;
    letter-spacing: -0.02em;
    transition: opacity 0.2s;
  }

  .jp-navbar__logo:hover {
    opacity: 0.8;
  }

  .jp-navbar__links {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 2rem;
    align-items: center;
  }

  .jp-navbar__link {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition:
      color 0.2s,
      opacity 0.2s;
    position: relative;
  }

  .jp-navbar__link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background-color: #e8ff47;
    transition: width 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .jp-navbar__link:hover {
    color: #ffffff;
  }

  .jp-navbar__link:hover::after {
    width: 100%;
  }

  .jp-navbar__link--active {
    color: #e8ff47;
  }

  .jp-navbar__link--active::after {
    width: 100%;
    background-color: #e8ff47;
  }

  .jp-navbar__hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 2rem;
    height: 2rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .jp-navbar__bar {
    display: block;
    width: 22px;
    height: 2px;
    background-color: rgba(255, 255, 255, 0.8);
    border-radius: 2px;
    transition:
      transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.3s,
      background-color 0.2s;
  }

  .jp-navbar__hamburger[aria-expanded='true'] .jp-navbar__bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
    background-color: #e8ff47;
  }

  .jp-navbar__hamburger[aria-expanded='true'] .jp-navbar__bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .jp-navbar__hamburger[aria-expanded='true'] .jp-navbar__bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
    background-color: #e8ff47;
  }

  @media (max-width: 768px) {
    .jp-navbar__hamburger {
      display: flex;
    }

    .jp-navbar__links {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      gap: 0;
      background-color: rgba(10, 10, 10, 0.95);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(232, 255, 71, 0.15);
      padding: 0;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .jp-navbar__links[data-open='true'] {
      max-height: 400px;
    }

    .jp-navbar__links li {
      width: 100%;
    }

    .jp-navbar__link {
      display: block;
      padding: 1rem 1.5rem;
      font-size: 1rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .jp-navbar__link::after {
      display: none;
    }
  }
</style>

<script>
  const navbar = document.getElementById('jp-navbar');
  const toggle = document.getElementById('jp-navbar-toggle');
  const links = document.getElementById('jp-navbar-links');

  // Glassmorphism on scroll
  if (navbar) {
    const onScroll = () => {
      if (window.scrollY > 20) {
        navbar.classList.add('jp-navbar--scrolled');
      } else {
        navbar.classList.remove('jp-navbar--scrolled');
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // Hamburger toggle
  if (toggle && links) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      links.dataset.open = String(!expanded);
    });

    // Close on link click (mobile)
    links.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        links.dataset.open = 'false';
      });
    });
  }

  // Active link tracking via IntersectionObserver
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('.jp-navbar__link');
  if (navLinks.length > 0) {
    const sectionIds = Array.from(navLinks)
      .map((a) => {
        try {
          return new URL(a.href, window.location.href).hash.slice(1);
        } catch {
          return '';
        }
      })
      .filter(Boolean);

    if (sectionIds.length > 0) {
      const sections = sectionIds
        .map((id) => document.getElementById(id))
        .filter((el): el is HTMLElement => el !== null);

      if (sections.length > 0) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                navLinks.forEach((link) => link.classList.remove('jp-navbar__link--active'));
                const active = document.querySelector<HTMLAnchorElement>(
                  `.jp-navbar__link[href="#${entry.target.id}"]`
                );
                active?.classList.add('jp-navbar__link--active');
              }
            });
          },
          { rootMargin: '-20% 0px -70% 0px' }
        );

        sections.forEach((section) => observer.observe(section));
      }
    }
  }
</script>
