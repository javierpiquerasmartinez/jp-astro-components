---
import type { ButtonProps } from './Button.types';

type Props = ButtonProps;

const { variant = 'primary', href, external = false } = Astro.props;

const externalAttrs = external
  ? { target: '_blank', rel: 'noopener noreferrer' }
  : {};
---

{
  href ? (
    <a href={href} class:list={['jp-button', `jp-button--${variant}`]} {...externalAttrs}>
      <slot />
    </a>
  ) : (
    <button type="button" class:list={['jp-button', `jp-button--${variant}`]}>
      <slot />
    </button>
  )
}

<style>
  .jp-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 600;
    font-family: inherit;
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition:
      opacity 0.2s,
      border-color 0.2s,
      color 0.2s;
  }

  .jp-button--primary {
    background: var(--jp-color-accent, #e8ff47);
    color: #0a0a0a;
  }

  .jp-button--primary:hover {
    opacity: 0.85;
  }

  .jp-button--ghost {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: rgba(255, 255, 255, 0.7);
  }

  .jp-button--ghost:hover {
    border-color: rgba(255, 255, 255, 0.4);
    color: #ffffff;
  }
</style>
