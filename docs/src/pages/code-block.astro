---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Navbar, PageTitle, CodeBlock } from 'jp-astro-components';

const links = [
  { label: 'Inicio', href: '#hero' },
  { label: 'Variantes', href: '#variants' },
  { label: 'Uso', href: '#usage' },
];

const importCode = `import { CodeBlock } from 'jp-astro-components';`;

const exampleAccent = `<CodeBlock label="IMPORTAR" code={importCode} accent />`;

const exampleNoLabel = `<CodeBlock code={snippet} />`;

const exampleMultiline = `<CodeBlock label="EJEMPLO" code={snippet} />`;

const multilineSnippet = `---
import { Navbar } from 'jp-astro-components';

const links = [
  { label: 'Inicio', href: '#hero' },
  { label: 'Proyectos', href: '#projects' },
];
---

<Navbar links={links} logo="Mi sitio" />`;
---

<BaseLayout title="CodeBlock">
  <Navbar links={links} logo="jp-astro" logoHref="/" sticky={true} />

  <main>
    <section id="hero" style="padding-top: 2rem;">
      <PageTitle accent="CodeBlock">component</PageTitle>
      <p style="color: var(--jp-text-muted); max-width: 600px; margin-bottom: 2rem;">
        Bloque de código con etiqueta opcional. Pensado para mostrar snippets en páginas de
        documentación. La prop <code style="color: var(--jp-color-accent); font-size: 0.9em;"
          >accent</code
        > usa el color de la marca para imports de una línea.
      </p>
      <CodeBlock label="IMPORTAR" code={importCode} accent />
    </section>

    <section id="variants" style="padding-top: 2rem;">
      <h2 style="font-size: 1.5rem; font-weight: 600; margin-bottom: 1.5rem;">Variantes</h2>

      <div style="display: flex; flex-direction: column; gap: 1.5rem;">
        <!-- Con accent -->
        <div
          style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; overflow: hidden;"
        >
          <div style="padding: 1.5rem;">
            <CodeBlock
              label="IMPORTAR"
              code={`import { Navbar, Button } from 'jp-astro-components';`}
              accent
            />
          </div>
          <div style="border-top: 1px solid rgba(255,255,255,0.08); background: rgba(0,0,0,0.2);">
            <CodeBlock code={exampleAccent} />
          </div>
        </div>

        <!-- Sin label -->
        <div
          style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; overflow: hidden;"
        >
          <div style="padding: 1.5rem;">
            <CodeBlock code={`<Button href="/ruta">Texto</Button>`} />
          </div>
          <div style="border-top: 1px solid rgba(255,255,255,0.08); background: rgba(0,0,0,0.2);">
            <CodeBlock code={exampleNoLabel} />
          </div>
        </div>

        <!-- Multi-línea con label -->
        <div
          style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; overflow: hidden;"
        >
          <div style="padding: 1.5rem;">
            <CodeBlock label="EJEMPLO" code={multilineSnippet} />
          </div>
          <div style="border-top: 1px solid rgba(255,255,255,0.08); background: rgba(0,0,0,0.2);">
            <CodeBlock code={exampleMultiline} />
          </div>
        </div>
      </div>
    </section>

    <section id="usage" style="padding-top: 2rem;">
      <h2 style="font-size: 1.5rem; font-weight: 600; margin-bottom: 1rem;">Props</h2>
      <table
        style="width: 100%; border-collapse: collapse; font-size: 0.875rem; color: var(--jp-text-muted);"
      >
        <thead>
          <tr style="border-bottom: 1px solid rgba(255,255,255,0.1);">
            <th style="text-align: left; padding: 0.5rem 1rem 0.5rem 0; color: white;">Prop</th>
            <th style="text-align: left; padding: 0.5rem 1rem 0.5rem 0; color: white;">Tipo</th>
            <th style="text-align: left; padding: 0.5rem 0; color: white;">Default</th>
          </tr>
        </thead>
        <tbody>
          <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
            <td style="padding: 0.5rem 1rem 0.5rem 0; color: var(--jp-color-accent);">code</td>
            <td style="padding: 0.5rem 1rem 0.5rem 0;">string</td>
            <td style="padding: 0.5rem 0;">— (requerido)</td>
          </tr>
          <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
            <td style="padding: 0.5rem 1rem 0.5rem 0; color: var(--jp-color-accent);">label</td>
            <td style="padding: 0.5rem 1rem 0.5rem 0;">string</td>
            <td style="padding: 0.5rem 0;">—</td>
          </tr>
          <tr>
            <td style="padding: 0.5rem 1rem 0.5rem 0; color: var(--jp-color-accent);">accent</td>
            <td style="padding: 0.5rem 1rem 0.5rem 0;">boolean</td>
            <td style="padding: 0.5rem 0;">false</td>
          </tr>
        </tbody>
      </table>
    </section>

    <div style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.08);">
      <a href="/" style="color: var(--jp-text-muted); text-decoration: none; font-size: 0.875rem;">
        ← Volver al inicio
      </a>
    </div>
  </main>
</BaseLayout>
