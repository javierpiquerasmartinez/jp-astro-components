---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Section, Article } from 'jp-astro-components';
---

<BaseLayout title="Layout">
  <style>
    .page-title {
      margin-bottom: 2rem;
      padding-bottom: 1rem;
      border-bottom: 2px solid #e5e7eb;
    }

    .demo-block {
      background: white;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      padding: 2rem;
      margin-bottom: 2rem;
    }

    .demo-block h3 {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #9ca3af;
      margin-bottom: 1rem;
    }

    .code {
      background: #f3f4f6;
      border-radius: 4px;
      padding: 0.75rem 1rem;
      font-family: monospace;
      font-size: 0.85rem;
      margin-top: 1rem;
      color: #374151;
    }

    /* Estilos base para los componentes de layout */
    :global(.jp-section) {
      padding: 1.5rem;
      background: #f0fdf4;
      border: 1px dashed #86efac;
      border-radius: 6px;
      margin-bottom: 1rem;
    }

    :global(.jp-article) {
      padding: 1.5rem;
      background: #eff6ff;
      border: 1px dashed #93c5fd;
      border-radius: 6px;
      margin-bottom: 1rem;
    }
  </style>

  <h1 class="page-title">Layout</h1>

  <div class="demo-block">
    <h3>Section</h3>
    <Section label="Ejemplo de sección">
      <p>Contenido dentro de un &lt;section&gt; semántico.</p>
    </Section>
    <div class="code">
      &lt;Section label="Mi sección"&gt;<br />
      &nbsp;&nbsp;&lt;p&gt;Contenido...&lt;/p&gt;<br />
      &lt;/Section&gt;
    </div>
  </div>

  <div class="demo-block">
    <h3>Article</h3>
    <Article label="Ejemplo de artículo">
      <p>Contenido dentro de un &lt;article&gt; semántico.</p>
    </Article>
    <div class="code">
      &lt;Article label="Mi artículo"&gt;<br />
      &nbsp;&nbsp;&lt;p&gt;Contenido...&lt;/p&gt;<br />
      &lt;/Article&gt;
    </div>
  </div>
</BaseLayout>
