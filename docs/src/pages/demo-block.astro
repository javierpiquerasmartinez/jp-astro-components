---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Navbar, PageTitle, Button, CodeBlock, DemoBlock, PropsTable, Sidebar } from 'jp-astro-components';

const links = [
  { label: 'Inicio', href: '#hero' },
  { label: 'Ejemplo', href: '#example' },
  { label: 'Uso', href: '#usage' },
];

const importCode = `import { DemoBlock } from 'jp-astro-components';`;

const exampleCode = `<DemoBlock code="<Button href=\\"#\\">Acción →</Button>">
  <Button href="#">Acción →</Button>
</DemoBlock>`;

const props = [
  { name: 'code', type: 'string', default: '— (requerido)' },
  { name: 'label', type: 'string', default: '—' },
  { name: 'accent', type: 'boolean', default: 'false' },
];
---

<BaseLayout title="DemoBlock">
  <Navbar links={links} logo="jp-astro" logoHref="/" sticky={true} />

  <main>
    <div class="doc-layout">
      <Sidebar />
      <div class="doc-content">
        <section id="hero" style="padding-top: 2rem;">
          <PageTitle accent="DemoBlock">component</PageTitle>
          <p style="color: var(--jp-text-muted); max-width: 600px; margin-bottom: 2rem;">
            Wrapper para páginas de documentación. Muestra un preview del componente arriba y el código
            de uso abajo. El slot es la demo en vivo; la prop <code
              style="color: var(--jp-color-accent); font-size: 0.9em;">code</code
            > es el string que se pasa a <code style="color: var(--jp-color-accent); font-size: 0.9em;"
              >CodeBlock</code
            >.
          </p>
          <CodeBlock label="IMPORTAR" code={importCode} accent />
        </section>

        <section id="example" style="padding-top: 2rem;">
          <h2 style="font-size: 1.5rem; font-weight: 600; margin-bottom: 1.5rem;">Ejemplo</h2>
          <DemoBlock code={exampleCode}>
            <DemoBlock code={`<Button href="#">Acción →</Button>`}>
              <Button href="#">Acción →</Button>
            </DemoBlock>
          </DemoBlock>
        </section>

        <section id="usage" style="padding-top: 2rem;">
          <h2 style="font-size: 1.5rem; font-weight: 600; margin-bottom: 1rem;">Props</h2>
          <PropsTable props={props} />
        </section>

        <div style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.08);">
          <a href="/" style="color: var(--jp-text-muted); text-decoration: none; font-size: 0.875rem;">
            ← Volver al inicio
          </a>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .doc-layout {
    display: flex;
    gap: 3rem;
    align-items: flex-start;
  }

  .doc-content {
    flex: 1;
    min-width: 0;
  }

  @media (max-width: 768px) {
    .doc-layout {
      flex-direction: column;
    }
  }
</style>
