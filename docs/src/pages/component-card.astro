---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Navbar, PageTitle, CodeBlock, DemoBlock, ComponentCard, PropsTable } from 'jp-astro-components';

const links = [
  { label: 'Inicio', href: '#hero' },
  { label: 'Ejemplo', href: '#example' },
  { label: 'Uso', href: '#usage' },
];

const importCode = `import { ComponentCard } from 'jp-astro-components';`;

const exampleCode = `<ComponentCard
  href="/navbar"
  category="Navigation"
  title="Navbar"
  description="Barra de navegación fija con glassmorphism."
/>`;

const props = [
  { name: 'href', type: 'string', default: '— (requerido)' },
  { name: 'category', type: 'string', default: '— (requerido)' },
  { name: 'title', type: 'string', default: '— (requerido)' },
  { name: 'description', type: 'string', default: '— (requerido)' },
];
---

<BaseLayout title="ComponentCard">
  <Navbar links={links} logo="jp-astro" logoHref="/" sticky={true} />

  <main>
    <section id="hero" style="padding-top: 2rem;">
      <PageTitle accent="ComponentCard">component</PageTitle>
      <p style="color: var(--jp-text-muted); max-width: 600px; margin-bottom: 2rem;">
        Tarjeta enlazable para listar componentes o secciones en un índice. Muestra categoría,
        título y descripción.
      </p>
      <CodeBlock label="IMPORTAR" code={importCode} accent />
    </section>

    <section id="example" style="padding-top: 2rem;">
      <h2 style="font-size: 1.5rem; font-weight: 600; margin-bottom: 1.5rem;">Ejemplo</h2>
      <DemoBlock code={exampleCode}>
        <div style="width: 100%; max-width: 320px;">
          <ComponentCard
            href="/navbar"
            category="Navigation"
            title="Navbar"
            description="Barra de navegación fija con glassmorphism."
          />
        </div>
      </DemoBlock>
    </section>

    <section id="usage" style="padding-top: 2rem;">
      <h2 style="font-size: 1.5rem; font-weight: 600; margin-bottom: 1rem;">Props</h2>
      <PropsTable props={props} />
    </section>

    <div style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.08);">
      <a href="/" style="color: var(--jp-text-muted); text-decoration: none; font-size: 0.875rem;">
        ← Volver al inicio
      </a>
    </div>
  </main>
</BaseLayout>
