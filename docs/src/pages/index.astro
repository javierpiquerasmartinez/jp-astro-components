---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Navbar, PageTitle } from 'jp-astro-components';

const navLinks = [{ label: 'Componentes', href: '#components' }];
---

<BaseLayout title="Inicio">
  <Navbar links={navLinks} logo="jp-astro" logoHref="/" />

  <main>
    <section style="padding-top: 2rem; text-align: center; padding-bottom: 4rem;">
      <p
        style="font-size: 0.8rem; letter-spacing: 0.15em; color: var(--jp-color-accent); text-transform: uppercase; margin-bottom: 1.5rem;"
      >
        Component Library
      </p>
      <PageTitle>jp-astro-components</PageTitle>
      <p
        style="font-size: 1.1rem; color: var(--jp-text-muted); max-width: 520px; margin: 0 auto 3rem;"
      >
        Librería de componentes Astro reutilizables. Diseñada para proyectos modernos con identidad
        visual clara.
      </p>

      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a
          href="/navbar"
          style="display: inline-flex; align-items: center; gap: 0.5rem; background: var(--jp-color-accent); color: #0a0a0a; font-weight: 600; padding: 0.75rem 1.5rem; border-radius: 6px; text-decoration: none; font-size: 0.9rem; transition: opacity 0.2s;"
        >
          Ver componentes →
        </a>
        <a
          href="https://www.npmjs.com/package/jp-astro-components"
          style="display: inline-flex; align-items: center; gap: 0.5rem; border: 1px solid rgba(255,255,255,0.15); color: rgba(255,255,255,0.7); padding: 0.75rem 1.5rem; border-radius: 6px; text-decoration: none; font-size: 0.9rem; transition: border-color 0.2s, color 0.2s;"
        >
          npm package
        </a>
      </div>
    </section>

    <section id="components">
      <h2
        style="font-size: 0.8rem; letter-spacing: 0.15em; color: var(--jp-text-muted); text-transform: uppercase; margin-bottom: 1.5rem;"
      >
        Componentes
      </h2>

      <div
        style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1rem;"
      >
        <a
          href="/navbar"
          style="display: block; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; padding: 1.5rem; text-decoration: none; color: inherit; transition: border-color 0.2s, background-color 0.2s;"
        >
          <p
            style="font-size: 0.7rem; letter-spacing: 0.12em; color: var(--jp-color-accent); text-transform: uppercase; margin-bottom: 0.75rem;"
          >
            Navigation
          </p>
          <h3 style="font-size: 1.1rem; font-weight: 600; margin-bottom: 0.5rem;">Navbar</h3>
          <p style="color: var(--jp-text-muted); font-size: 0.875rem; line-height: 1.5;">
            Barra de navegación fija con glassmorphism, hamburger menu y active link tracking.
          </p>
        </a>
        <a
          href="/page-title"
          style="display: block; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; padding: 1.5rem; text-decoration: none; color: inherit; transition: border-color 0.2s, background-color 0.2s;"
        >
          <p
            style="font-size: 0.7rem; letter-spacing: 0.12em; color: var(--jp-color-accent); text-transform: uppercase; margin-bottom: 0.75rem;"
          >
            Typography
          </p>
          <h3 style="font-size: 1.1rem; font-weight: 600; margin-bottom: 0.5rem;">PageTitle</h3>
          <p style="color: var(--jp-text-muted); font-size: 0.875rem; line-height: 1.5;">
            Heading principal con palabra accent resaltada. Responsive via clamp().
          </p>
        </a>
        <a
          href="/base-layout"
          style="display: block; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; padding: 1.5rem; text-decoration: none; color: inherit; transition: border-color 0.2s, background-color 0.2s;"
        >
          <p
            style="font-size: 0.7rem; letter-spacing: 0.12em; color: var(--jp-color-accent); text-transform: uppercase; margin-bottom: 0.75rem;"
          >
            Layout
          </p>
          <h3 style="font-size: 1.1rem; font-weight: 600; margin-bottom: 0.5rem;">BaseLayout</h3>
          <p style="color: var(--jp-text-muted); font-size: 0.875rem; line-height: 1.5;">
            Shell HTML con Geist, CSS variables, reset y animaciones incluidas.
          </p>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
