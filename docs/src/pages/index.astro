---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Navbar, PageTitle, Button, ComponentCard } from 'jp-astro-components';

const navLinks = [{ label: 'Componentes', href: '#components' }];
---

<BaseLayout title="Inicio">
  <Navbar links={navLinks} logo="jp-astro" logoHref="/" />

  <main>
    <section style="padding-top: 2rem; text-align: center; padding-bottom: 4rem;">
      <p
        style="font-size: 0.8rem; letter-spacing: 0.15em; color: var(--jp-color-accent); text-transform: uppercase; margin-bottom: 1.5rem;"
      >
        Component Library
      </p>
      <PageTitle>jp-astro-components</PageTitle>
      <p
        style="font-size: 1.1rem; color: var(--jp-text-muted); max-width: 520px; margin: 0 auto 3rem;"
      >
        Librería de componentes Astro reutilizables. Diseñada para proyectos modernos con identidad
        visual clara.
      </p>

      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <Button href="/navbar">Ver componentes</Button>
        <Button href="https://www.npmjs.com/package/jp-astro-components" variant="ghost" external
          >npm package ↗</Button
        >
      </div>
    </section>

    <section id="components">
      <h2
        style="font-size: 0.8rem; letter-spacing: 0.15em; color: var(--jp-text-muted); text-transform: uppercase; margin-bottom: 1.5rem;"
      >
        Componentes
      </h2>

      <div
        style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1rem;"
      >
        <ComponentCard
          href="/navbar"
          category="Navigation"
          title="Navbar"
          description="Barra de navegación fija con glassmorphism, hamburger menu y active link tracking."
        />
        <ComponentCard
          href="/page-title"
          category="Typography"
          title="PageTitle"
          description="Heading principal con palabra accent resaltada. Responsive via clamp()."
        />
        <ComponentCard
          href="/base-layout"
          category="Layout"
          title="BaseLayout"
          description="Shell HTML con Geist, CSS variables, reset y animaciones incluidas."
        />
        <ComponentCard
          href="/code-block"
          category="UI"
          title="CodeBlock"
          description="Bloque de código con etiqueta y variante accent para imports."
        />
        <ComponentCard
          href="/button"
          category="UI"
          title="Button"
          description="Botón primary y ghost. Renderiza <a> o <button> según el contexto."
        />
        <ComponentCard
          href="/demo-block"
          category="UI"
          title="DemoBlock"
          description="Wrapper de preview + código para páginas de documentación."
        />
        <ComponentCard
          href="/component-card"
          category="UI"
          title="ComponentCard"
          description="Tarjeta enlazable para listar componentes en un índice."
        />
        <ComponentCard
          href="/props-table"
          category="UI"
          title="PropsTable"
          description="Tabla de props reutilizable para páginas de documentación."
        />
      </div>
    </section>
  </main>
</BaseLayout>
