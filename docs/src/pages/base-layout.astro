---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Navbar, PageTitle, CodeBlock, PropsTable, Sidebar } from 'jp-astro-components';

const links = [
  { label: 'Inicio', href: '#hero' },
  { label: 'Qué incluye', href: '#includes' },
  { label: 'Uso', href: '#usage' },
];

const importCode = `import { BaseLayout } from 'jp-astro-components';`;

const exampleCode = `---
import { BaseLayout } from 'jp-astro-components';
---

<BaseLayout title="Mi página" description="Descripción opcional" lang="es">
  <!-- Todo el contenido va aquí -->
  <main>
    <h1>Hola mundo</h1>
  </main>
</BaseLayout>`;

const props = [
  { name: 'title', type: 'string', default: '— (requerido)' },
  { name: 'description', type: 'string', default: '—' },
  { name: 'lang', type: 'string', default: '"es"' },
];
---

<BaseLayout title="BaseLayout">
  <Navbar links={links} logo="jp-astro" logoHref="/" sticky={true} />

  <main>
    <div class="doc-layout">
      <Sidebar />
      <div class="doc-content">
        <section id="hero" style="padding-top: 2rem;">
          <PageTitle accent="BaseLayout">component</PageTitle>
          <p style="color: var(--jp-text-muted); max-width: 600px; margin-bottom: 2rem;">
            Shell HTML completo con Geist font, CSS variables del sistema de diseño, estilos globales
            y animaciones. Úsalo como base para cualquier página.
          </p>
          <CodeBlock label="IMPORTAR" code={importCode} accent />
        </section>

        <section id="includes" style="padding-top: 2rem;">
          <h2 style="font-size: 1.5rem; font-weight: 600; margin-bottom: 1.5rem;">Qué incluye</h2>
          <ul style="color: var(--jp-text-muted); display: flex; flex-direction: column; gap: 0.75rem; list-style: none; padding: 0; margin-bottom: 2rem;">
            <li>✦ <code style="color: rgba(255,255,255,0.7);">&lt;!doctype html&gt;</code> + meta charset y viewport</li>
            <li>✦ Geist font cargada desde Google Fonts</li>
            <li>✦ CSS variables: <code style="color: var(--jp-color-accent);">--jp-color-bg</code>, <code style="color: var(--jp-color-accent);">--jp-color-accent</code>, <code style="color: var(--jp-color-accent);">--jp-text-muted</code>…</li>
            <li>✦ Reset de box-sizing y scroll suave (respeta <code style="color: rgba(255,255,255,0.7);">prefers-reduced-motion</code>)</li>
            <li>✦ Body: fondo oscuro, Geist, antialiasing</li>
            <li>✦ Keyframes: <code style="color: rgba(255,255,255,0.7);">fade-in</code>, <code style="color: rgba(255,255,255,0.7);">fade-up</code>, <code style="color: rgba(255,255,255,0.7);">slide-from-top</code>, <code style="color: rgba(255,255,255,0.7);">slide-from-bottom</code></li>
            <li>✦ Utilidad <code style="color: rgba(255,255,255,0.7);">.sr-only</code></li>
            <li>✦ <code style="color: rgba(255,255,255,0.7);">&lt;slot /&gt;</code> para el contenido de la página</li>
          </ul>
        </section>

        <section id="usage" style="padding-top: 2rem;">
          <h2 style="font-size: 1.5rem; font-weight: 600; margin-bottom: 1.5rem;">Uso</h2>
          <CodeBlock label="EJEMPLO" code={exampleCode} />
          <h3 style="font-size: 1.1rem; font-weight: 600; margin: 1.5rem 0 1rem;">Props</h3>
          <PropsTable props={props} />
        </section>

        <div style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.08);">
          <a href="/" style="color: var(--jp-text-muted); text-decoration: none; font-size: 0.875rem;">
            ← Volver al inicio
          </a>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .doc-layout {
    display: flex;
    gap: 3rem;
    align-items: flex-start;
  }

  .doc-content {
    flex: 1;
    min-width: 0;
  }

  @media (max-width: 768px) {
    .doc-layout {
      flex-direction: column;
    }
  }
</style>
