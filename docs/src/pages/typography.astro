---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Heading } from 'jp-astro-components';
---

<BaseLayout title="Typography">
  <style>
    .page-title {
      margin-bottom: 2rem;
      padding-bottom: 1rem;
      border-bottom: 2px solid #e5e7eb;
    }

    .demo-block {
      background: white;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      padding: 2rem;
      margin-bottom: 2rem;
    }

    .demo-block h3 {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #9ca3af;
      margin-bottom: 1rem;
    }

    .code {
      background: #f3f4f6;
      border-radius: 4px;
      padding: 0.75rem 1rem;
      font-family: monospace;
      font-size: 0.85rem;
      margin-top: 1rem;
      color: #374151;
    }

    /* Estilos base para los componentes Heading */
    :global(.jp-heading--1) { font-size: 2.5rem; font-weight: 700; line-height: 1.2; }
    :global(.jp-heading--2) { font-size: 2rem; font-weight: 700; line-height: 1.3; }
    :global(.jp-heading--3) { font-size: 1.5rem; font-weight: 600; line-height: 1.4; }
    :global(.jp-heading--4) { font-size: 1.25rem; font-weight: 600; line-height: 1.4; }
    :global(.jp-heading--5) { font-size: 1rem; font-weight: 600; line-height: 1.5; }
    :global(.jp-heading--6) { font-size: 0.875rem; font-weight: 600; line-height: 1.5; }
  </style>

  <h1 class="page-title">Typography</h1>

  <div class="demo-block">
    <h3>Heading (todos los niveles)</h3>
    <Heading level={1}>Heading nivel 1</Heading>
    <Heading level={2}>Heading nivel 2</Heading>
    <Heading level={3}>Heading nivel 3</Heading>
    <Heading level={4}>Heading nivel 4</Heading>
    <Heading level={5}>Heading nivel 5</Heading>
    <Heading level={6}>Heading nivel 6</Heading>
    <div class="code">
      &lt;Heading level=&#123;1&#125;&gt;Heading nivel 1&lt;/Heading&gt;<br />
      &lt;Heading level=&#123;2&#125;&gt;Heading nivel 2&lt;/Heading&gt;
    </div>
  </div>
</BaseLayout>
