---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Navbar, PageTitle, Button } from 'jp-astro-components';

const links = [
  { label: 'Inicio', href: '#hero' },
  { label: 'Variantes', href: '#variants' },
  { label: 'Uso', href: '#usage' },
];
---

<BaseLayout title="Button">
  <Navbar links={links} logo="jp-astro" logoHref="/" sticky={true} />

  <main>
    <section id="hero" style="padding-top: 2rem;">
      <PageTitle accent="Button">component</PageTitle>
      <p style="color: var(--jp-text-muted); max-width: 600px; margin-bottom: 2rem;">
        Botón con dos variantes: <strong style="color: white;">primary</strong> y <strong
          style="color: white;">ghost</strong
        >. Renderiza <code style="color: var(--jp-color-accent); font-size: 0.9em;">&lt;a&gt;</code> si tiene
        <code style="color: var(--jp-color-accent); font-size: 0.9em;">href</code>, o <code
          style="color: var(--jp-color-accent); font-size: 0.9em;">&lt;button&gt;</code> si no.
      </p>

      <div
        style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; padding: 1.5rem; margin-bottom: 2rem;"
      >
        <p style="color: var(--jp-text-muted); font-size: 0.85rem; margin-bottom: 0.75rem;">
          IMPORTAR
        </p>
        <pre
          style="margin: 0; font-size: 0.9rem; color: var(--jp-color-accent);"><code>import &#123; Button &#125; from 'jp-astro-components';</code></pre>
      </div>
    </section>

    <section id="variants" style="padding-top: 2rem;">
      <h2 style="font-size: 1.5rem; font-weight: 600; margin-bottom: 1.5rem;">Variantes</h2>

      <div style="display: flex; flex-direction: column; gap: 1.5rem;">
        <!-- Primary -->
        <div
          style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; overflow: hidden;"
        >
          <div style="padding: 2rem; display: flex; gap: 1rem; flex-wrap: wrap;">
            <Button href="#">Acción principal →</Button>
          </div>
          <div
            style="border-top: 1px solid rgba(255,255,255,0.08); padding: 1rem 1.5rem; background: rgba(0,0,0,0.2);"
          >
            <pre style="margin: 0; font-size: 0.8rem; color: var(--jp-text-muted);"><code>&lt;Button href="#"&gt;Acción principal →&lt;/Button&gt;</code></pre>
          </div>
        </div>

        <!-- Ghost -->
        <div
          style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; overflow: hidden;"
        >
          <div style="padding: 2rem; display: flex; gap: 1rem; flex-wrap: wrap;">
            <Button href="#" variant="ghost">Acción secundaria</Button>
          </div>
          <div
            style="border-top: 1px solid rgba(255,255,255,0.08); padding: 1rem 1.5rem; background: rgba(0,0,0,0.2);"
          >
            <pre style="margin: 0; font-size: 0.8rem; color: var(--jp-text-muted);"><code>&lt;Button href="#" variant="ghost"&gt;Acción secundaria&lt;/Button&gt;</code></pre>
          </div>
        </div>

        <!-- Ambas + external -->
        <div
          style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; overflow: hidden;"
        >
          <div style="padding: 2rem; display: flex; gap: 1rem; flex-wrap: wrap;">
            <Button href="/navbar">Ir a Navbar →</Button>
            <Button href="https://astro.build" variant="ghost" external>astro.build ↗</Button>
          </div>
          <div
            style="border-top: 1px solid rgba(255,255,255,0.08); padding: 1rem 1.5rem; background: rgba(0,0,0,0.2);"
          >
            <pre style="margin: 0; font-size: 0.8rem; color: var(--jp-text-muted);"><code>&lt;Button href="/navbar"&gt;Ir a Navbar →&lt;/Button&gt;
&lt;Button href="https://astro.build" variant="ghost" external&gt;astro.build ↗&lt;/Button&gt;</code></pre>
          </div>
        </div>

        <!-- Con acción via id -->
        <div
          style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; overflow: hidden;"
        >
          <div style="padding: 2rem; display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
            <Button id="demo-btn">Haz click</Button>
            <span id="demo-output" style="color: var(--jp-text-muted); font-size: 0.875rem;"></span>
          </div>
          <div
            style="border-top: 1px solid rgba(255,255,255,0.08); padding: 1rem 1.5rem; background: rgba(0,0,0,0.2);"
          >
            <pre style="margin: 0; font-size: 0.8rem; color: var(--jp-text-muted);"><code>&lt;Button id="demo-btn"&gt;Haz click&lt;/Button&gt;

&lt;script&gt;
  document.getElementById('demo-btn').addEventListener('click', () =&gt; &#123;
    // tu lógica aquí
  &#125;);
&lt;/script&gt;</code></pre>
          </div>
        </div>
      </div>
    </section>

    <section id="usage" style="padding-top: 2rem;">
      <h2 style="font-size: 1.5rem; font-weight: 600; margin-bottom: 1rem;">Props</h2>
      <table
        style="width: 100%; border-collapse: collapse; font-size: 0.875rem; color: var(--jp-text-muted);"
      >
        <thead>
          <tr style="border-bottom: 1px solid rgba(255,255,255,0.1);">
            <th style="text-align: left; padding: 0.5rem 1rem 0.5rem 0; color: white;">Prop</th>
            <th style="text-align: left; padding: 0.5rem 1rem 0.5rem 0; color: white;">Tipo</th>
            <th style="text-align: left; padding: 0.5rem 0; color: white;">Default</th>
          </tr>
        </thead>
        <tbody>
          <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
            <td style="padding: 0.5rem 1rem 0.5rem 0; color: var(--jp-color-accent);">variant</td>
            <td style="padding: 0.5rem 1rem 0.5rem 0;">'primary' | 'ghost'</td>
            <td style="padding: 0.5rem 0;">'primary'</td>
          </tr>
          <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
            <td style="padding: 0.5rem 1rem 0.5rem 0; color: var(--jp-color-accent);">href</td>
            <td style="padding: 0.5rem 1rem 0.5rem 0;">string</td>
            <td style="padding: 0.5rem 0;">— (renderiza &lt;button&gt;)</td>
          </tr>
          <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
            <td style="padding: 0.5rem 1rem 0.5rem 0; color: var(--jp-color-accent);">external</td>
            <td style="padding: 0.5rem 1rem 0.5rem 0;">boolean</td>
            <td style="padding: 0.5rem 0;">false</td>
          </tr>
          <tr>
            <td style="padding: 0.5rem 1rem 0.5rem 0; color: var(--jp-color-accent);">...rest</td>
            <td style="padding: 0.5rem 1rem 0.5rem 0;">HTMLButtonAttributes | HTMLAnchorAttributes</td>
            <td style="padding: 0.5rem 0;">—</td>
          </tr>
        </tbody>
      </table>
    </section>

    <div style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.08);">
      <a href="/" style="color: var(--jp-text-muted); text-decoration: none; font-size: 0.875rem;">
        ← Volver al inicio
      </a>
    </div>
  </main>
</BaseLayout>

<script>
  let count = 0;
  const btn = document.getElementById('demo-btn');
  const output = document.getElementById('demo-output');
  btn?.addEventListener('click', () => {
    count++;
    if (output) output.textContent = `clicked ${count} ${count === 1 ? 'vez' : 'veces'}`;
  });
</script>
